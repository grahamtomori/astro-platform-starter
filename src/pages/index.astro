---
import '../styles/global.css';
const year = new Date().getFullYear();
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Graham Tomori</title>
        <style>
            .carousel-wrapper {
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            .carousel-scene {
                width: 980px;
                height: 320px;
                perspective: 1400px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: default;
            }

            .carousel-drum {
                width: 980px;
                height: 320px;
                position: relative;
                transform-style: preserve-3d;
                transition: transform 0.72s cubic-bezier(0.65, 0, 0.2, 1);
            }

            .drum-panel {
                position: absolute;
                width: 980px;
                height: 320px;
                border-radius: 28px;
                backface-visibility: hidden;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 48px 72px;
                box-sizing: border-box;
                background: #e6ddd1;
                box-shadow:
                    0 24px 64px rgba(59, 47, 47, 0.28),
                    0 6px 18px rgba(59, 47, 47, 0.14);
            }

            .drum-panel:nth-child(1) {
                transform: rotateX(0deg) translateZ(160px);
            }
            .drum-panel:nth-child(2) {
                transform: rotateX(90deg) translateZ(160px);
            }
            .drum-panel:nth-child(3) {
                transform: rotateX(180deg) translateZ(160px);
            }
            .drum-panel:nth-child(4) {
                transform: rotateX(270deg) translateZ(160px);
            }

            .panel-label {
                font-size: 0.72rem;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: #8a7060;
                margin-bottom: 10px;
                font-family: sans-serif;
            }

            .panel-title {
                font-size: 1.9rem;
                font-family: Georgia, serif;
                color: #3b2f2f;
                margin-bottom: 12px;
                font-weight: bold;
            }

            .panel-body {
                font-size: 1rem;
                color: #3b2f2f;
                line-height: 1.7;
                max-width: 680px;
            }

            .panel-link {
                display: inline-block;
                margin-top: 20px;
                padding: 9px 24px;
                background: #3b2f2f;
                color: #f2efe7;
                border-radius: 8px;
                text-decoration: none;
                font-size: 0.92rem;
                transition: background 0.2s;
            }

            .panel-link:hover {
                background: #5c4a4a;
            }

            .carousel-dots {
                display: flex;
                justify-content: center;
                gap: 10px;
                margin-top: 24px;
            }

            .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: #c4b78b;
                opacity: 0.35;
                transition: opacity 0.3s;
                cursor: pointer;
            }

            .dot.active {
                opacity: 1;
            }
        </style>
    </head>

    <body class="font-sans bg-gray-100">
        <!-- Navbar -->
        <nav class="fixed top-0 left-0 w-full bg-[#3b2f2f] shadow-md z-50">
            <div class="flex justify-between items-center text-white w-full pl-3">
                <div class="flex items-center space-x-3">
                    <img src="/images/stretched-globe-csa-images.png" alt="Globe Logo" class="h-16 w-auto object-contain relative top-0.5" />
                    <div class="flex flex-col justify-center">
                        <span class="text-xl font-bold text-gray-100">Graham Tomori</span>
                        <span class="text-sm italic text-gray-300">Curiosity in Motion</span>
                    </div>
                </div>
                <div class="space-x-6 mr-6">
                    <a href="/about" class="hover:text-[#c4b78b]">About</a>
                    <a href="/projects" class="hover:text-[#c4b78b]">Projects</a>
                    <a href="/Ivory" class="hover:text-[#c4b78b]">Ivory</a>
                    <a href="/resume" class="hover:text-[#c4b78b]">Resume</a>
                    <a href="/contact" class="hover:text-[#c4b78b]">Contact</a>
                </div>
            </div>
        </nav>

        <!-- Hero Section -->
        <section id="home" class="min-h-screen flex items-center justify-end bg-[url('/images/rockefeller-god-3.jpg')] bg-cover bg-center relative">
            <div class="bg-[#3b2f2f] bg-opacity-75 p-11.5 rounded-3xl text-center mr-24 mt-24 max-w-lg">
                <h1 class="text-5xl font-serif text-[#e0d8c3] mb-6">Welcome</h1>
                <p class="text-lg text-[#dcd2c0] leading-relaxed">
                    My name is Graham Tomori. I study Political Science and Economics at
                    <a href="https://www.butler.edu/arts-sciences/political-science/" class="italic" target="_blank" rel="noopener noreferrer">
                        Butler University,
                    </a>
                    with a focus on grand strategy, political theory, and international order.
                </p>
            </div>
        </section>

        <!-- Literature Section -->
        <section id="readings" class="py-24 bg-[#ece6dd]">
            <div class="max-w-5xl mx-auto px-6">
                <h2 class="text-3xl font-serif font-bold mb-2 text-[#3b2f2f]">Literature -</h2>
                <p class="text-base text-[#3b2f2f] mb-8">The content I've been engaging with recently:</p>
                <div class="grid md:grid-cols-3 gap-8">
                    <div class="p-6 bg-[#e6ddd1] rounded-xl shadow hover:shadow-lg transition">
                        <h3 class="font-bold text-lg text-[#3b2f2f] mb-2">Zbig</h3>
                        <p class="text-[#3b2f2f]">Edward Luce</p>
                    </div>
                    <div class="p-6 bg-[#e6ddd1] rounded-xl shadow hover:shadow-lg transition">
                        <h3 class="font-bold text-lg text-[#3b2f2f] mb-2">Why Nations Fail</h3>
                        <p class="text-[#3b2f2f]">Daron Acemoglu & James A. Robinson</p>
                    </div>
                    <div class="p-6 bg-[#e6ddd1] rounded-xl shadow hover:shadow-lg transition">
                        <h3 class="font-bold text-lg text-[#3b2f2f] mb-2">How China Escaped the Poverty Trap</h3>
                        <p class="text-[#3b2f2f]">Yuen Yuen Ang</p>
                    </div>
                    <div class="p-6 bg-[#e6ddd1] rounded-xl shadow hover:shadow-lg transition">
                        <h3 class="font-bold text-lg text-[#3b2f2f] mb-2">Leadership</h3>
                        <p class="text-[#3b2f2f]">Henry Kissinger</p>
                    </div>
                    <div class="p-6 bg-[#e6ddd1] rounded-xl shadow hover:shadow-lg transition">
                        <h3 class="font-bold text-lg text-[#3b2f2f] mb-2">The Stranger</h3>
                        <p class="text-[#3b2f2f]">Albert Camus</p>
                    </div>
                    <div class="p-6 bg-[#e6ddd1] rounded-xl shadow hover:shadow-lg transition">
                        <h3 class="font-bold text-lg text-[#3b2f2f] mb-2">Political Order and Political Decay</h3>
                        <p class="text-[#3b2f2f]">Francis Fukuyama</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 3D Drum Carousel -->
        <section id="drum-section" class="py-24 bg-[#d9c8b3]">
            <div class="carousel-wrapper">
                <div class="carousel-scene" id="carousel-scene">
                    <div class="carousel-drum" id="drum">
                        <div class="drum-panel">
                            <span class="panel-label">01 — About</span>
                            <h2 class="panel-title">Graham Tomori</h2>
                            <p class="panel-body">
                                First-year at Butler University studying Political Science and Economics. D1 distance runner. Focused on grand strategy,
                                political theory, and the architecture of international order.
                            </p>
                            <a href="/about" class="panel-link">Read More</a>
                        </div>

                        <div class="drum-panel">
                            <span class="panel-label">02 — Projects</span>
                            <h2 class="panel-title">Work</h2>
                            <p class="panel-body">
                                MOCKIMFPROJECT — a social media account examining ideas in global development and institutional economics. Personal website
                                built with Astro + Tailwind.
                            </p>
                            <a href="/projects" class="panel-link">View Projects</a>
                        </div>

                        <div class="drum-panel">
                            <span class="panel-label">03 — Resume</span>
                            <h2 class="panel-title">Background</h2>
                            <p class="panel-body">
                                Education, competitions, and experience — including first place in the Ayn Rand Institute's Fountainhead Essay Competition,
                                2024.
                            </p>
                            <a href="/resume" class="panel-link">View Resume</a>
                        </div>

                        <div class="drum-panel">
                            <span class="panel-label">04 — Contact</span>
                            <h2 class="panel-title">Get in Touch</h2>
                            <p class="panel-body">
                                Reach me at
                                <a href="mailto:contactgrahamtomori@gmail.com" style="color:#7a8465; text-decoration:underline;">
                                    contactgrahamtomori@gmail.com
                                </a>. I keep this minimal for now.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="carousel-dots" id="dots">
                    <div class="dot active" data-index="0"></div>
                    <div class="dot" data-index="1"></div>
                    <div class="dot" data-index="2"></div>
                    <div class="dot" data-index="3"></div>
                </div>
            </div>
        </section>
    </body>

    <footer class="bg-[#3b2f2f] text-gray-100 py-6">
        <div class="max-w-6xl mx-auto px-6 text-center">
            &copy; {year} Graham Tomori. All rights reserved.
        </div>
    </footer>

    <script>
        const drum = document.getElementById('drum');
        const dots = document.querySelectorAll('.dot');
        const scene = document.getElementById('carousel-scene');
        const PANEL_COUNT = 4;
        const THRESHOLD = 20;

        let rotation = 0;
        let locked = false;
        let mouseOver = false;
        let accumulator = 0;

        scene.addEventListener('mouseenter', () => {
            mouseOver = true;
            accumulator = 0;
        });
        scene.addEventListener('mouseleave', () => {
            mouseOver = false;
            accumulator = 0;
        });

        function getActiveIndex() {
            return (((-rotation / 90) % PANEL_COUNT) + PANEL_COUNT) % PANEL_COUNT;
        }

        function step(dir) {
            rotation -= dir * 90;
            drum.style.transform = `rotateX(${rotation}deg)`;
            const active = getActiveIndex();
            dots.forEach((d, i) => d.classList.toggle('active', i === active));
        }

        window.addEventListener(
            'wheel',
            (e) => {
                if (!mouseOver) return;
                e.preventDefault();
                if (locked) return;

                accumulator += e.deltaY;

                if (Math.abs(accumulator) >= THRESHOLD) {
                    const dir = accumulator > 0 ? 1 : -1;
                    accumulator = 0;
                    locked = true;
                    step(dir);
                    setTimeout(() => {
                        locked = false;
                    }, 800);
                }
            },
            { passive: false }
        );

        dots.forEach((dot, i) => {
            dot.addEventListener('click', () => {
                if (locked) return;
                const active = getActiveIndex();
                let diff = i - active;
                if (diff > 2) diff -= 4;
                if (diff < -2) diff += 4;
                if (diff === 0) return;
                locked = true;
                rotation -= diff * 90;
                drum.style.transform = `rotateX(${rotation}deg)`;
                dots.forEach((d, j) => d.classList.toggle('active', j === i));
                setTimeout(() => {
                    locked = false;
                }, 800);
            });
        });
    </script>
</html>
