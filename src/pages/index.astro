---
import '../styles/global.css';
const year = new Date().getFullYear();
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Graham Tomori</title>
        <style>
            .carousel-wrapper {
                display: flex;
                flex-direction: column;
                align-items: center;
            }

            .carousel-scene {
                width: 980px;
                height: 320px;
                perspective: 1400px;
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: grab;
            }

            .carousel-drum {
                width: 980px;
                height: 320px;
                position: relative;
                transform-style: preserve-3d;
                transition: transform 0.6s cubic-bezier(0.65, 0, 0.35, 1);
                filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.15));
            }

            .drum-panel {
                position: absolute;
                width: 980px;
                height: 320px;
                border-radius: 28px;
                backface-visibility: hidden;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 48px 72px;
                box-sizing: border-box;
                background: linear-gradient(145deg, #e6ddd1, #dcd2c0);
                box-shadow:
                    0 24px 64px rgba(59, 47, 47, 0.28),
                    0 6px 18px rgba(59, 47, 47, 0.14);
                transition:
                    transform 0.6s ease,
                    filter 0.6s ease;
            }

            /* Slight depth blur / lighting effect */
            .drum-panel.active {
                filter: brightness(1) blur(0px);
                z-index: 10;
            }
            .drum-panel:not(.active) {
                filter: brightness(0.85) blur(1px);
                z-index: 1;
            }

            .drum-panel:nth-child(1) {
                transform: rotateX(0deg) translateZ(160px);
            }
            .drum-panel:nth-child(2) {
                transform: rotateX(90deg) translateZ(160px);
            }
            .drum-panel:nth-child(3) {
                transform: rotateX(180deg) translateZ(160px);
            }
            .drum-panel:nth-child(4) {
                transform: rotateX(270deg) translateZ(160px);
            }

            .panel-label {
                font-size: 0.72rem;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: #8a7060;
                margin-bottom: 10px;
                font-family: sans-serif;
            }
            .panel-title {
                font-size: 1.9rem;
                font-family: Georgia, serif;
                color: #3b2f2f;
                margin-bottom: 12px;
                font-weight: bold;
            }
            .panel-body {
                font-size: 1rem;
                color: #3b2f2f;
                line-height: 1.7;
                max-width: 680px;
            }
            .panel-link {
                display: inline-block;
                margin-top: 20px;
                padding: 9px 24px;
                background: #3b2f2f;
                color: #f2efe7;
                border-radius: 8px;
                text-decoration: none;
                font-size: 0.92rem;
                transition: background 0.2s;
            }
            .panel-link:hover {
                background: #5c4a4a;
            }

            .carousel-dots {
                display: flex;
                justify-content: center;
                gap: 10px;
                margin-top: 24px;
            }
            .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: #c4b78b;
                opacity: 0.35;
                transition: opacity 0.3s;
                cursor: pointer;
            }
            .dot.active {
                opacity: 1;
            }
        </style>
    </head>

    <body class="font-sans bg-gray-100">
        <!-- Navbar, Hero, Literature sections unchanged -->

        <!-- 3D Drum Carousel -->
        <section id="drum-section" class="py-24 bg-[#d9c8b3]">
            <div class="carousel-wrapper">
                <div class="carousel-scene" id="carousel-scene">
                    <div class="carousel-drum" id="drum">
                        <div class="drum-panel">
                            <span class="panel-label">01 — About</span>
                            <h2 class="panel-title">Graham Tomori</h2>
                            <p class="panel-body">
                                First-year at Butler University studying Political Science and Economics. D1 distance runner. Focused on grand strategy,
                                political theory, and the architecture of international order.
                            </p>
                            <a href="/about" class="panel-link">Read More</a>
                        </div>
                        <div class="drum-panel">
                            <span class="panel-label">02 — Projects</span>
                            <h2 class="panel-title">Work</h2>
                            <p class="panel-body">
                                MOCKIMFPROJECT — a social media account examining ideas in global development and institutional economics. Personal website
                                built with Astro + Tailwind.
                            </p>
                            <a href="/projects" class="panel-link">View Projects</a>
                        </div>
                        <div class="drum-panel">
                            <span class="panel-label">03 — Resume</span>
                            <h2 class="panel-title">Background</h2>
                            <p class="panel-body">
                                Education, competitions, and experience — including first place in the Ayn Rand Institute's Fountainhead Essay Competition,
                                2024.
                            </p>
                            <a href="/resume" class="panel-link">View Resume</a>
                        </div>
                        <div class="drum-panel">
                            <span class="panel-label">04 — Contact</span>
                            <h2 class="panel-title">Get in Touch</h2>
                            <p class="panel-body">
                                Reach me at
                                <a href="mailto:contactgrahamtomori@gmail.com" style="color:#7a8465; text-decoration:underline;">
                                    contactgrahamtomori@gmail.com
                                </a>. I keep this minimal for now.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="carousel-dots" id="dots">
                    <div class="dot active" data-index="0"></div>
                    <div class="dot" data-index="1"></div>
                    <div class="dot" data-index="2"></div>
                    <div class="dot" data-index="3"></div>
                </div>
            </div>
        </section>
    </body>

    <footer class="bg-[#3b2f2f] text-gray-100 py-6">
        <div class="max-w-6xl mx-auto px-6 text-center">
            &copy; {year} Graham Tomori. All rights reserved.
        </div>
    </footer>

    <script>
        const drum = document.getElementById('drum');
        const dots = document.querySelectorAll('.dot');
        const scene = document.getElementById('carousel-scene');
        const PANEL_COUNT = 4;

        let rotation = 0; // total rotation in degrees
        let targetRotation = 0; // smooth target for inertia
        let velocity = 0; // scroll velocity
        let isDragging = false;
        let lastTime = performance.now();
        let snapTimeout;

        function isOverScene(e) {
            const rect = scene.getBoundingClientRect();
            return e.clientX >= rect.left && e.clientX <= rect.right && e.clientY >= rect.top && e.clientY <= rect.bottom;
        }

        function getActiveIndex() {
            return (((-rotation / 90) % PANEL_COUNT) + PANEL_COUNT) % PANEL_COUNT;
        }

        function updateDots() {
            const active = getActiveIndex();
            dots.forEach((d, i) => d.classList.toggle('active', i === active));
            const panels = drum.querySelectorAll('.drum-panel');
            panels.forEach((p, i) => p.classList.toggle('active', i === active));
        }

        function animate() {
            const now = performance.now();
            const dt = (now - lastTime) / 1000;
            lastTime = now;

            // Smoothly apply velocity for Apple-style scroll inertia
            rotation += velocity * dt * 60; // scale to degrees
            velocity *= 0.92; // damping factor

            drum.style.transform = `rotateX(${rotation}deg)`;
            updateDots();

            requestAnimationFrame(animate);
        }

        // Start animation loop
        animate();

        window.addEventListener(
            'wheel',
            (e) => {
                if (!isOverScene(e)) return;
                e.preventDefault();
                velocity += -e.deltaY * 0.5; // adjust sensitivity for trackpad
                clearTimeout(snapTimeout);
                snapTimeout = setTimeout(() => {
                    // Snap to nearest panel
                    const nearest = Math.round(rotation / 90) * 90;
                    rotation = nearest;
                    velocity = 0;
                    updateDots();
                }, 150); // short delay for Apple-like snap
            },
            { passive: false }
        );

        // Dots click handler
        dots.forEach((dot, i) => {
            dot.addEventListener('click', () => {
                const nearest = i * -90;
                rotation = nearest;
                velocity = 0;
                updateDots();
            });
        });
    </script>
</html>
